{
  "name": "SIINDEX — New Citizen Welcome (Supabase → Telegram)",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": "REPLACE: select your webhook after import",
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 150 },
        "restore": {
          "parameters": {
            "hook": {
              "data": { "editable": true, "name": "Supabase new citizen webhook" }
            }
          }
        },
        "parameters": [
          { "name": "hook", "type": "hook:gateway-webhook", "label": "Webhook", "required": true },
          { "name": "maxResults", "type": "number", "label": "Maximum number of results" }
        ]
      }
    },
    {
      "id": 2,
      "module": "telegram-bot-api:sendMessage",
      "version": 1,
      "parameters": {
        "connection": "REPLACE: add your SIINDEXbot connection after import"
      },
      "mapper": {
        "chat_id": "REPLACE_WITH_CHANNEL_CHAT_ID",
        "text": "🌐 New sovereign citizen\n\n*{{1.name}}.IN$DEX* is live.\n\nCitizen #{{1.citizen_number}} of the IN$DEX civilisation.\n\nNo bank. No ID needed.\n2% Civilisation Law — the only fee, forever.\n\nWelcome home.\n\n— SIINDEX",
        "parse_mode": "Markdown",
        "disable_notification": false
      },
      "metadata": {
        "designer": { "x": 400, "y": 150 }
      }
    }
  ],
  "metadata": {
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "zone": "us2.make.com"
  }
}
