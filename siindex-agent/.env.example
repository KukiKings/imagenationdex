# SIINDEX Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — Supabase (IN$DEX backend)
SUPABASE_URL=https://zljgthfzbalsunuoohcd.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional — override model (default: claude-haiku-4-5-20251001)
SIINDEX_MODEL=claude-haiku-4-5-20251001

# Optional — TTS voice override
SIINDEX_VOICE=en-AU-NatashaNeural
