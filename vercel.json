{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    {
      "src": "^/$",
      "dest": "/home-v2.html"
    },
    {
      "src": "^/app$",
      "dest": "/index.html"
    },
    {
      "src": "^/onboard$",
      "dest": "/terms-of-service.html"
    },
    {
      "src": "^/join$",
      "dest": "/waitlist.html"
    },
    {
      "src": "^/claim$",
      "dest": "/claim-gift.html"
    },
    {
      "src": "^/token$",
      "dest": "/token.html"
    },
    {
      "src": "^/about$",
      "dest": "/about.html"
    },
    {
      "src": "^/how$",
      "dest": "/how-it-works.html"
    },
    {
      "src": "^/genesis$",
      "dest": "/genesis-offer.html"
    },
    {
      "src": "^/contact$",
      "dest": "/contact.html"
    },
    {
      "src": "^/(.+\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "^/(.+\\.(css|js|png|jpg|svg|ico|woff|woff2|ttf|xml|txt))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/404.html",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.+\\.(js|css|png|jpg|svg|ico|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
